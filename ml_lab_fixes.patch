+"""
+Decision Tree Router - calls the from-scratch TreeService and TreeParser.
+"""
+
+from fastapi import APIRouter, HTTPException
+from typing import Dict
+
+from app.models.tree_models import DecisionTreeRequest, DecisionTreeResponse, TreeNode
+from app.services.tree_service import TreeService
+from app.utils.tree_parser import TreeParser
+
+router = APIRouter()
+
+
+@router.post("/api/decision_tree", response_model=DecisionTreeResponse)
+async def run_decision_tree(request: DecisionTreeRequest) -> DecisionTreeResponse:
+    try:
+        X, y, feature_names = TreeService.load_dataset(request.dataset)
+
+        # Train from-scratch CART tree
+        root, score, depth, n_leaves, importances = TreeService.train_tree(
+            X, y, request.task, request.criterion, request.max_depth,
+            request.min_samples_split, request.min_samples_leaf,
+        )
+
+        # Class names per dataset (for classifier leaf labels)
+        class_names = None
+        if request.task == "classifier":
+            if request.dataset == "iris":
+                class_names = ["setosa", "versicolor", "virginica"]
+            elif request.dataset == "breast_cancer":
+                class_names = ["malignant", "benign"]
+            elif request.dataset == "blobs":
+                class_names = ["cluster_0", "cluster_1", "cluster_2"]
+
+        # Choose attribute key matching the trained criterion
+        criterion_key = request.criterion if request.task == "classifier" else "mse"
+
+        tree_json_dict = TreeParser.custom_tree_to_json(
+            root, feature_names, criterion_key, class_names,
+        )
+
+        # Recursively convert dict → Pydantic TreeNode for response validation
+        def to_tree_node(node_dict: Dict) -> TreeNode:
+            children = None
+            if "children" in node_dict and node_dict["children"]:
+                children = [to_tree_node(c) for c in node_dict["children"]]
+            return TreeNode(
+                name=node_dict["name"],
+                attributes=node_dict["attributes"],
+                children=children,
+            )
+
+        tree_json = to_tree_node(tree_json_dict)
+
+        feature_importances = {
+            feature_names[i]: float(importances[i]) for i in range(len(feature_names))
+        }
+
+        return DecisionTreeResponse(
+            tree_json=tree_json,
+            accuracy=float(score),
+            depth=depth,
+            n_leaves=n_leaves,
+            feature_importances=feature_importances,
+        )
+
+    except Exception as e:
+        raise HTTPException(status_code=500, detail=f"Internal server error: {str(e)}")
