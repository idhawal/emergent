+"""
+Tree Service - From-scratch CART decision tree implementation.
+
+Implements:
+    - DecisionTree training with Gini / Entropy (classifier) and MSE (regressor)
+    - Best-split search by exhaustive feature/threshold scan
+    - Pruning via max_depth, min_samples_split, min_samples_leaf
+    - Custom train/test split, accuracy and R² helpers
+
+Datasets:
+    - "iris" / "breast_cancer" : sklearn data BUNDLES (data only — no algorithms)
+    - "blobs"                  : hand-coded Gaussian-blob generator
+
+No sklearn.tree.* or sklearn.metrics.* is used for the algorithms themselves.
+"""
+
+import numpy as np
+from typing import Tuple, List, Dict, Optional, Callable, Any
+
+# Datasets are pure data files bundled with sklearn — no ML algorithm involved.
+from sklearn.datasets import load_iris, load_breast_cancer
+
+
+# ---------------------------------------------------------------------------
+# Dataset helpers
+# ---------------------------------------------------------------------------
+def _make_blobs_manual(
+    n_samples: int = 300,
+    n_features: int = 4,
+    centers: int = 3,
+    cluster_std: float = 0.8,
+    random_state: int = 42,
+) -> Tuple[np.ndarray, np.ndarray]:
+    """Hand-coded equivalent of sklearn make_blobs."""
+    rng = np.random.default_rng(random_state)
+    centers_arr = rng.uniform(-5, 5, size=(centers, n_features))
+    samples_per_center = n_samples // centers
+    Xs, ys = [], []
+    for c in range(centers):
+        Xs.append(centers_arr[c] + rng.standard_normal((samples_per_center, n_features)) * cluster_std)
+        ys.append(np.full(samples_per_center, c, dtype=int))
+    # remainder
+    rem = n_samples - samples_per_center * centers
+    if rem > 0:
+        Xs.append(centers_arr[0] + rng.standard_normal((rem, n_features)) * cluster_std)
+        ys.append(np.zeros(rem, dtype=int))
+    X = np.vstack(Xs)
+    y = np.concatenate(ys)
+    perm = rng.permutation(len(y))
+    return X[perm], y[perm]
+
+
+def _train_test_split_manual(
+    X: np.ndarray,
+    y: np.ndarray,
+    test_size: float = 0.2,
+    random_state: int = 42,
+) -> Tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
+    rng = np.random.default_rng(random_state)
+    n = len(y)
+    idx = rng.permutation(n)
+    cut = int(round(n * (1 - test_size)))
+    train, test = idx[:cut], idx[cut:]
+    return X[train], X[test], y[train], y[test]
+
+
+# ---------------------------------------------------------------------------
+# Impurity / split metrics — pure NumPy
+# ---------------------------------------------------------------------------
+def _gini(y: np.ndarray) -> float:
+    if len(y) == 0:
+        return 0.0
+    _, counts = np.unique(y, return_counts=True)
+    p = counts / len(y)
+    return float(1.0 - np.sum(p * p))
+
+
+def _entropy(y: np.ndarray) -> float:
+    if len(y) == 0:
+        return 0.0
+    _, counts = np.unique(y, return_counts=True)
+    p = counts / len(y)
+    p = p[p > 0]
+    return float(-np.sum(p * np.log2(p)))
+
+
+def _mse(y: np.ndarray) -> float:
+    if len(y) == 0:
+        return 0.0
+    return float(np.var(y))
+
+
+def _best_split(
+    X: np.ndarray,
+    y: np.ndarray,
+    impurity_fn: Callable[[np.ndarray], float],
+    parent_impurity: float,
+    min_samples_leaf: int,
+) -> Tuple[Optional[int], Optional[float], float]:
+    """Exhaustive split search over all features × candidate thresholds."""
+    n_samples, n_features = X.shape
+    best_gain = 0.0
+    best_feat: Optional[int] = None
+    best_thresh: Optional[float] = None
+
+    for j in range(n_features):
+        col = X[:, j]
+        sorted_vals = np.unique(col)
+        if sorted_vals.size < 2:
+            continue
+        # candidate thresholds = midpoints between consecutive unique values
+        thresholds = (sorted_vals[:-1] + sorted_vals[1:]) / 2.0
+
+        for t in thresholds:
+            left_mask = col <= t
+            right_mask = ~left_mask
+            n_left = int(left_mask.sum())
+            n_right = n_samples - n_left
+            if n_left < min_samples_leaf or n_right < min_samples_leaf:
+                continue
+            left_imp = impurity_fn(y[left_mask])
+            right_imp = impurity_fn(y[right_mask])
+            weighted = (n_left / n_samples) * left_imp + (n_right / n_samples) * right_imp
+            gain = parent_impurity - weighted
+            if gain > best_gain:
+                best_gain = gain
+                best_feat = j
+                best_thresh = float(t)
+
+    return best_feat, best_thresh, best_gain
+
+
+# ---------------------------------------------------------------------------
+# Tree node + builder
+# ---------------------------------------------------------------------------
+def _build_node(
+    X: np.ndarray,
+    y: np.ndarray,
+    task: str,
+    criterion: str,
+    max_depth: Optional[int],
+    min_samples_split: int,
+    min_samples_leaf: int,
+    n_classes: Optional[int],
+    depth: int = 0,
+) -> Dict[str, Any]:
+    samples = int(len(y))
+
+    if criterion == "gini":
+        impurity_fn: Callable[[np.ndarray], float] = _gini
+    elif criterion == "entropy":
+        impurity_fn = _entropy
+    else:  # regressor uses MSE regardless of criterion label
+        impurity_fn = _mse
+
+    impurity = impurity_fn(y)
+
+    if task == "classifier":
+        assert n_classes is not None
+        class_dist = [int((y == c).sum()) for c in range(n_classes)]
+        prediction: Any = int(np.argmax(class_dist)) if samples > 0 else 0
+    else:
+        # Regression: store mean as prediction; keep "class_dist" key compatible
+        # with the spec/UI by encoding the leaf value as a 1-element list.
+        mean_val = float(np.mean(y)) if samples > 0 else 0.0
+        class_dist = [mean_val]
+        prediction = mean_val
+
+    node: Dict[str, Any] = {
+        "is_leaf": True,
+        "samples": samples,
+        "impurity": float(impurity),
+        "class_dist": class_dist,
+        "prediction": prediction,
+    }
+
+    # Stopping criteria
+    if (
+        (max_depth is not None and depth >= max_depth)
+        or samples < min_samples_split
+        or impurity < 1e-12
+    ):
+        return node
+
+    feat, thresh, gain = _best_split(X, y, impurity_fn, impurity, min_samples_leaf)
+    if feat is None or gain <= 0.0:
+        return node
+
+    left_mask = X[:, feat] <= thresh
+    right_mask = ~left_mask
+
+    node["is_leaf"] = False
+    node["feature"] = int(feat)
+    node["threshold"] = float(thresh)
+    node["left"] = _build_node(
+        X[left_mask], y[left_mask], task, criterion,
+        max_depth, min_samples_split, min_samples_leaf, n_classes, depth + 1,
+    )
+    node["right"] = _build_node(
+        X[right_mask], y[right_mask], task, criterion,
+        max_depth, min_samples_split, min_samples_leaf, n_classes, depth + 1,
+    )
+    return node
+
+
+def _predict_one(node: Dict[str, Any], x: np.ndarray) -> Any:
+    while not node["is_leaf"]:
+        if x[node["feature"]] <= node["threshold"]:
+            node = node["left"]
+        else:
+            node = node["right"]
+    return node["prediction"]
+
+
+def _predict(node: Dict[str, Any], X: np.ndarray) -> np.ndarray:
+    return np.array([_predict_one(node, X[i]) for i in range(X.shape[0])])
+
+
+def _tree_depth(node: Dict[str, Any]) -> int:
+    if node["is_leaf"]:
+        return 0
+    return 1 + max(_tree_depth(node["left"]), _tree_depth(node["right"]))
+
+
+def _n_leaves(node: Dict[str, Any]) -> int:
+    if node["is_leaf"]:
+        return 1
+    return _n_leaves(node["left"]) + _n_leaves(node["right"])
+
+
+def _feature_importances(root: Dict[str, Any], n_features: int) -> np.ndarray:
+    """Sum of impurity reduction × node-sample-share, normalized to 1."""
+    importances = np.zeros(n_features)
+    total_samples = root["samples"]
+
+    def visit(n: Dict[str, Any]) -> None:
+        if n["is_leaf"]:
+            return
+        left = n["left"]
+        right = n["right"]
+        ns = n["samples"]
+        gain = (
+            n["impurity"]
+            - (left["samples"] / ns) * left["impurity"]
+            - (right["samples"] / ns) * right["impurity"]
+        )
+        importances[n["feature"]] += gain * (ns / total_samples)
+        visit(left)
+        visit(right)
+
+    visit(root)
+    s = importances.sum()
+    if s > 0:
+        importances = importances / s
+    return importances
+
+
+# ---------------------------------------------------------------------------
+# Public service
+# ---------------------------------------------------------------------------
+class TreeService:
+    """From-scratch decision tree service."""
+
+    @staticmethod
+    def load_dataset(dataset_name: str) -> Tuple[np.ndarray, np.ndarray, List[str]]:
+        if dataset_name == "iris":
+            data = load_iris()
+            return data.data, data.target, list(data.feature_names)
+        if dataset_name == "breast_cancer":
+            data = load_breast_cancer()
+            return data.data, data.target, list(data.feature_names)
+        if dataset_name == "blobs":
+            X, y = _make_blobs_manual()
+            feature_names = [f"feature_{i}" for i in range(X.shape[1])]
+            return X, y, feature_names
+        raise ValueError(f"Unknown dataset: {dataset_name}")
+
+    @staticmethod
+    def train_tree(
+        X: np.ndarray,
+        y: np.ndarray,
+        task: str,
+        criterion: str,
+        max_depth: Optional[int],
+        min_samples_split: int,
+        min_samples_leaf: int,
+    ) -> Tuple[Dict[str, Any], float, int, int, np.ndarray]:
+        """Train a tree and return (root_node, score, depth, n_leaves, importances)."""
+        # 80/20 split (stratification not implemented from scratch — uniform shuffle)
+        X_train, X_test, y_train, y_test = _train_test_split_manual(X, y, test_size=0.2)
+
+        n_classes: Optional[int] = None
+        if task == "classifier":
+            # Re-label so classes are contiguous 0..K-1 (in case of breast_cancer etc.)
+            uniq = np.unique(np.concatenate([y_train, y_test]))
+            n_classes = int(len(uniq))
+
+        root = _build_node(
+            X_train, y_train, task, criterion,
+            max_depth, min_samples_split, min_samples_leaf, n_classes,
+        )
+
+        # Score on the held-out set
+        y_pred = _predict(root, X_test)
+        if task == "classifier":
+            score = float(np.mean(y_pred == y_test))
+        else:
+            ss_res = float(np.sum((y_test - y_pred) ** 2))
+            ss_tot = float(np.sum((y_test - np.mean(y_test)) ** 2)) + 1e-12
+            score = float(1.0 - ss_res / ss_tot)
+
+        depth = _tree_depth(root)
+        n_leaves = _n_leaves(root)
+        importances = _feature_importances(root, X.shape[1])
+        return root, score, depth, n_leaves, importances
