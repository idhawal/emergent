+"""
+Tree Parser - Convert the from-scratch tree dict into react-d3-tree JSON.
+
+Input:  the nested dict returned by TreeService.train_tree(...)[0]
+Output: nested {name, attributes, children} structure per spec §5.1
+
+The criterion key in `attributes` matches the criterion the tree was trained on
+(`gini`, `entropy`, or `mse`) so the frontend can render the correct label.
+"""
+
+from typing import Dict, List, Optional, Any
+
+
+class TreeParser:
+    """Parse a custom tree node dict to react-d3-tree JSON."""
+
+    @staticmethod
+    def custom_tree_to_json(
+        root: Dict[str, Any],
+        feature_names: List[str],
+        criterion: str,
+        class_names: Optional[List[str]] = None,
+    ) -> Dict[str, Any]:
+        """Recursively walk the tree and build the spec §5.1 JSON.
+
+        Args:
+            root: The root node returned by TreeService.train_tree.
+            feature_names: Feature names for split rules.
+            criterion: 'gini' | 'entropy' | 'mse' — drives the attribute key.
+            class_names: Optional class label names for classifier leaves.
+        """
+        crit_key = criterion if criterion in ("gini", "entropy", "mse") else "impurity"
+
+        def walk(n: Dict[str, Any]) -> Dict[str, Any]:
+            attrs: Dict[str, Any] = {
+                crit_key: round(float(n["impurity"]), 4),
+                "samples": int(n["samples"]),
+                "class_dist": list(n["class_dist"]),
+            }
+
+            if n["is_leaf"]:
+                if class_names is not None:
+                    idx = int(n["prediction"]) if isinstance(n["prediction"], (int, float)) else 0
+                    label = class_names[idx] if 0 <= idx < len(class_names) else str(idx)
+                    name = f"class = {label}"
+                else:
+                    val = n["prediction"]
+                    name = f"value = {float(val):.3f}"
+                return {"name": name, "attributes": attrs}
+
+            feat_idx = n["feature"]
+            feat = feature_names[feat_idx] if feat_idx < len(feature_names) else f"feature_{feat_idx}"
+            name = f"{feat} ≤ {float(n['threshold']):.2f}"
+            return {
+                "name": name,
+                "attributes": attrs,
+                "children": [walk(n["left"]), walk(n["right"])],
+            }
+
+        return walk(root)
+
+    # Backwards-compatibility alias (older code or tests may still call this)
+    sklearn_tree_to_json = custom_tree_to_json  # type: ignore
