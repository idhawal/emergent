+"""
+Regression Service - From-scratch ML implementations.
+
+Every algorithm here is implemented manually with only NumPy primitives
+(linear algebra solve, basic arithmetic). No sklearn.linear_model is used.
+
+Algorithms:
+    - Linear Regression via custom Gradient Descent
+    - Polynomial Regression via Normal Equation (closed-form OLS)
+    - Ridge Regression via closed-form (X^T X + λI)^-1 X^T y
+    - Lasso Regression via coordinate descent with soft-thresholding
+    - Elastic Net via coordinate descent with mixed L1/L2 penalty
+
+All algorithms return both the learned coefficients and a cost_history list
+suitable for plotting on the frontend (single-element for closed-form, full
+iterative trace for GD / coordinate descent).
+"""
+
+import numpy as np
+from typing import Tuple, List, Optional
+
+
+class RegressionService:
+    """From-scratch regression algorithms."""
+
+    # ------------------------------------------------------------------
+    # Data + feature engineering
+    # ------------------------------------------------------------------
+    @staticmethod
+    def generate_synthetic_data(
+        n_samples: int = 80,
+        noise: float = 0.3,
+        poly_degree: int = 1,
+        random_state: int = 42,
+    ) -> Tuple[np.ndarray, np.ndarray]:
+        """Generate synthetic 1-D polynomial data with Gaussian noise."""
+        rng = np.random.default_rng(random_state)
+        X = np.linspace(-3, 3, n_samples).reshape(-1, 1)
+        true_coef = [1.5, -0.8, 0.4, -0.2]
+        y = np.zeros(n_samples)
+        for d in range(min(poly_degree + 1, len(true_coef))):
+            y += true_coef[d] * (X[:, 0] ** d)
+        y += rng.standard_normal(n_samples) * noise * 1.2
+        return X, y
+
+    @staticmethod
+    def polynomial_features(X: np.ndarray, degree: int, include_bias: bool = True) -> np.ndarray:
+        """Manually build polynomial design matrix [1, x, x^2, ..., x^degree]."""
+        m = X.shape[0]
+        cols: List[np.ndarray] = []
+        if include_bias:
+            cols.append(np.ones(m))
+        for d in range(1, degree + 1):
+            cols.append(X[:, 0] ** d)
+        return np.column_stack(cols)
+
+    @staticmethod
+    def feature_names(degree: int) -> List[str]:
+        names = ["bias"]
+        for d in range(1, degree + 1):
+            names.append(f"x^{d}")
+        return names
+
+    @staticmethod
+    def _mse_cost(theta: np.ndarray, X: np.ndarray, y: np.ndarray) -> float:
+        m = len(y)
+        return float((1.0 / (2.0 * m)) * np.sum((X @ theta - y) ** 2))
+
+    # ------------------------------------------------------------------
+    # 1. Linear Regression via Gradient Descent (from scratch)
+    # ------------------------------------------------------------------
+    @staticmethod
+    def gradient_descent(
+        X: np.ndarray,
+        y: np.ndarray,
+        learning_rate: float,
+        epochs: int,
+        early_stopping: bool = False,
+    ) -> Tuple[np.ndarray, List[float], Optional[int]]:
+        """Custom batch gradient descent for OLS.
+
+        θ ← θ − α · (1/m) X^T (Xθ − y)
+        Optionally halts when cost rises 5 times in a row.
+        """
+        m, n = X.shape
+        theta = np.zeros(n)
+        cost_history: List[float] = []
+        consecutive_increases = 0
+        stopped_at_epoch: Optional[int] = None
+
+        for epoch in range(epochs):
+            predictions = X @ theta
+            cost = float((1.0 / (2.0 * m)) * np.sum((predictions - y) ** 2))
+            cost_history.append(cost)
+
+            if early_stopping and len(cost_history) > 1:
+                if cost > cost_history[-2]:
+                    consecutive_increases += 1
+                    if consecutive_increases >= 5:
+                        stopped_at_epoch = epoch
+                        break
+                else:
+                    consecutive_increases = 0
+
+            gradients = (1.0 / m) * X.T @ (predictions - y)
+            theta = theta - learning_rate * gradients
+
+        return theta, cost_history, stopped_at_epoch
+
+    # ------------------------------------------------------------------
+    # 2. Polynomial Regression via Normal Equation (closed-form OLS)
+    # ------------------------------------------------------------------
+    @staticmethod
+    def normal_equation(X: np.ndarray, y: np.ndarray) -> np.ndarray:
+        """Closed-form OLS:  θ = (X^T X)^-1 X^T y, solved without inverting."""
+        return np.linalg.solve(X.T @ X, X.T @ y)
+
+    # ------------------------------------------------------------------
+    # 3. Ridge Regression via closed-form
+    # ------------------------------------------------------------------
+    @staticmethod
+    def ridge_closed_form(X: np.ndarray, y: np.ndarray, lam: float) -> np.ndarray:
+        """θ = (X^T X + λI*)^-1 X^T y where I* zeros the bias row/col."""
+        n = X.shape[1]
+        eye = np.eye(n)
+        eye[0, 0] = 0.0  # do not penalize the intercept
+        return np.linalg.solve(X.T @ X + lam * eye, X.T @ y)
+
+    # ------------------------------------------------------------------
+    # 4. Lasso Regression via Coordinate Descent
+    # ------------------------------------------------------------------
+    @staticmethod
+    def _soft_threshold(z: float, gamma: float) -> float:
+        if z > gamma:
+            return z - gamma
+        if z < -gamma:
+            return z + gamma
+        return 0.0
+
+    @staticmethod
+    def lasso_coordinate_descent(
+        X: np.ndarray,
+        y: np.ndarray,
+        lam: float,
+        max_iter: int = 300,
+        tol: float = 1e-6,
+    ) -> Tuple[np.ndarray, List[float]]:
+        """Cyclic coordinate descent for
+            J = (1/2m) ||y - Xθ||² + λ ||θ_{1:}||₁
+        Bias column (index 0) is not penalized.
+        """
+        m, n = X.shape
+        theta = np.zeros(n)
+        cost_history: List[float] = []
+        xj_sq = (X * X).sum(axis=0) + 1e-12
+
+        for _ in range(max_iter):
+            theta_old = theta.copy()
+            for j in range(n):
+                # residual with feature j removed
+                r = y - X @ theta + X[:, j] * theta[j]
+                rho = float(X[:, j] @ r)
+                if j == 0:
+                    theta[j] = rho / xj_sq[j]  # bias unpenalized
+                else:
+                    theta[j] = RegressionService._soft_threshold(rho, lam * m) / xj_sq[j]
+
+            res = X @ theta - y
+            cost = float(0.5 / m * np.sum(res ** 2) + lam * np.sum(np.abs(theta[1:])))
+            cost_history.append(cost)
+            if float(np.max(np.abs(theta - theta_old))) < tol:
+                break
+
+        return theta, cost_history
+
+    # ------------------------------------------------------------------
+    # 5. Elastic Net via Coordinate Descent
+    # ------------------------------------------------------------------
+    @staticmethod
+    def elastic_net_coordinate_descent(
+        X: np.ndarray,
+        y: np.ndarray,
+        lam: float,
+        l1_ratio: float,
+        max_iter: int = 300,
+        tol: float = 1e-6,
+    ) -> Tuple[np.ndarray, List[float]]:
+        """Cyclic coordinate descent for
+            J = (1/2m) ||y - Xθ||² + λ [l1_ratio ||θ||₁ + (1-l1_ratio)/2 ||θ||²]
+        Bias column (index 0) is not penalized.
+        """
+        m, n = X.shape
+        theta = np.zeros(n)
+        cost_history: List[float] = []
+        l1 = lam * l1_ratio
+        l2 = lam * (1.0 - l1_ratio)
+        xj_sq = (X * X).sum(axis=0) + 1e-12
+
+        for _ in range(max_iter):
+            theta_old = theta.copy()
+            for j in range(n):
+                r = y - X @ theta + X[:, j] * theta[j]
+                rho = float(X[:, j] @ r)
+                if j == 0:
+                    theta[j] = rho / xj_sq[j]
+                else:
+                    theta[j] = (
+                        RegressionService._soft_threshold(rho, l1 * m) / (xj_sq[j] + l2 * m)
+                    )
+
+            res = X @ theta - y
+            cost = float(
+                0.5 / m * np.sum(res ** 2)
+                + l1 * np.sum(np.abs(theta[1:]))
+                + 0.5 * l2 * np.sum(theta[1:] ** 2)
+            )
+            cost_history.append(cost)
+            if float(np.max(np.abs(theta - theta_old))) < tol:
+                break
+
+        return theta, cost_history
