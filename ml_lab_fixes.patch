+"""
+KNN Service - From-scratch K-Nearest Neighbors.
+
+Distance metrics, prediction, decision-boundary mesh and dataset generators are
+all hand-written. No sklearn.neighbors or sklearn.datasets is used.
+"""
+
+import numpy as np
+from typing import Tuple, List
+
+
+# ---------------------------------------------------------------------------
+# Hand-coded dataset generators
+# ---------------------------------------------------------------------------
+def _make_moons(n_samples: int = 200, noise: float = 0.2, random_state: int = 42):
+    rng = np.random.default_rng(random_state)
+    half = n_samples // 2
+    t1 = np.linspace(0, np.pi, half)
+    x1 = np.cos(t1) + rng.standard_normal(half) * noise
+    y1 = np.sin(t1) + rng.standard_normal(half) * noise
+
+    t2 = np.linspace(0, np.pi, n_samples - half)
+    x2 = 1 - np.cos(t2) + rng.standard_normal(n_samples - half) * noise
+    y2 = 0.5 - np.sin(t2) + rng.standard_normal(n_samples - half) * noise
+
+    X = np.vstack([np.column_stack([x1, y1]), np.column_stack([x2, y2])])
+    y = np.array([0] * half + [1] * (n_samples - half), dtype=int)
+    perm = rng.permutation(n_samples)
+    return X[perm], y[perm]
+
+
+def _make_circles(n_samples: int = 200, noise: float = 0.08, factor: float = 0.5, random_state: int = 42):
+    rng = np.random.default_rng(random_state)
+    half = n_samples // 2
+    t_outer = rng.uniform(0, 2 * np.pi, half)
+    t_inner = rng.uniform(0, 2 * np.pi, n_samples - half)
+
+    outer = np.column_stack([np.cos(t_outer), np.sin(t_outer)]) + rng.standard_normal((half, 2)) * noise
+    inner = factor * np.column_stack([np.cos(t_inner), np.sin(t_inner)]) + rng.standard_normal((n_samples - half, 2)) * noise
+
+    X = np.vstack([outer, inner])
+    y = np.array([0] * half + [1] * (n_samples - half), dtype=int)
+    perm = rng.permutation(n_samples)
+    return X[perm], y[perm]
+
+
+def _make_blobs(n_samples: int = 200, centers: int = 3, cluster_std: float = 0.6, random_state: int = 42):
+    rng = np.random.default_rng(random_state)
+    centers_arr = np.array([[-1.5, -1.0], [1.5, 1.2], [0.0, 1.5]])[:centers]
+    samples_per_center = n_samples // centers
+    Xs, ys = [], []
+    for c in range(centers):
+        Xs.append(centers_arr[c] + rng.standard_normal((samples_per_center, 2)) * cluster_std)
+        ys.append(np.full(samples_per_center, c, dtype=int))
+    rem = n_samples - samples_per_center * centers
+    if rem > 0:
+        Xs.append(centers_arr[0] + rng.standard_normal((rem, 2)) * cluster_std)
+        ys.append(np.zeros(rem, dtype=int))
+    X = np.vstack(Xs)
+    y = np.concatenate(ys)
+    perm = rng.permutation(len(y))
+    return X[perm], y[perm]
+
+
+def _make_sine(n_samples: int = 120, noise: float = 0.2, random_state: int = 42):
+    rng = np.random.default_rng(random_state)
+    x = np.linspace(-3, 3, n_samples)
+    y = np.sin(x) + rng.standard_normal(n_samples) * noise
+    X = np.column_stack([x, y])
+    return X, y
+
+
+# ---------------------------------------------------------------------------
+# KNN service
+# ---------------------------------------------------------------------------
+class KNNService:
+    """From-scratch KNN classifier + regressor."""
+
+    @staticmethod
+    def compute_distance(X1: np.ndarray, X2: np.ndarray, metric: str) -> np.ndarray:
+        """Pairwise distances. (m, p) result for X1 (m, n) vs X2 (p, n)."""
+        if metric == "euclidean":
+            X1_sq = np.sum(X1 ** 2, axis=1, keepdims=True)
+            X2_sq = np.sum(X2 ** 2, axis=1, keepdims=True).T
+            d_sq = np.maximum(X1_sq + X2_sq - 2.0 * X1 @ X2.T, 0.0)
+            return np.sqrt(d_sq)
+        if metric == "manhattan":
+            diff = X1[:, np.newaxis, :] - X2[np.newaxis, :, :]
+            return np.sum(np.abs(diff), axis=2)
+        raise ValueError(f"Unknown metric: {metric}")
+
+    @staticmethod
+    def predict(
+        X_train: np.ndarray,
+        y_train: np.ndarray,
+        X_test: np.ndarray,
+        k: int,
+        metric: str,
+        weights: str,
+        task: str,
+    ) -> np.ndarray:
+        distances = KNNService.compute_distance(X_test, X_train, metric)  # (p, m)
+        predictions: List = []
+        for i in range(X_test.shape[0]):
+            test_d = distances[i]
+            idx = np.argsort(test_d)[:k]
+            d_k = test_d[idx]
+            y_k = y_train[idx]
+
+            if task == "classification":
+                if weights == "uniform":
+                    classes, counts = np.unique(y_k, return_counts=True)
+                    pred = classes[int(np.argmax(counts))]
+                else:
+                    w = 1.0 / (d_k + 1e-10)
+                    classes = np.unique(y_k)
+                    tally = {c: float(np.sum(w[y_k == c])) for c in classes}
+                    pred = max(tally, key=tally.get)
+            else:  # regression
+                if weights == "uniform":
+                    pred = float(np.mean(y_k))
+                else:
+                    w = 1.0 / (d_k + 1e-10)
+                    pred = float(np.sum(w * y_k) / np.sum(w))
+
+            predictions.append(pred)
+        return np.array(predictions)
+
+    @staticmethod
+    def generate_decision_boundary(
+        X_train: np.ndarray,
+        y_train: np.ndarray,
+        k: int,
+        metric: str,
+        weights: str,
+        task: str,
+        grid_resolution: int = 60,
+    ) -> Tuple[np.ndarray, np.ndarray, np.ndarray]:
+        x_min, x_max = X_train[:, 0].min() - 0.6, X_train[:, 0].max() + 0.6
+        y_min, y_max = X_train[:, 1].min() - 0.6, X_train[:, 1].max() + 0.6
+        xx, yy = np.meshgrid(
+            np.linspace(x_min, x_max, grid_resolution),
+            np.linspace(y_min, y_max, grid_resolution),
+        )
+        grid_points = np.c_[xx.ravel(), yy.ravel()]
+        zz = KNNService.predict(X_train, y_train, grid_points, k, metric, weights, task).reshape(xx.shape)
+        return xx, yy, zz
+
+    @staticmethod
+    def generate_dataset(dataset_name: str) -> Tuple[np.ndarray, np.ndarray]:
+        if dataset_name == "moons":
+            return _make_moons()
+        if dataset_name == "circles":
+            return _make_circles()
+        if dataset_name == "blobs":
+            return _make_blobs()
+        if dataset_name == "sine":
+            return _make_sine()
+        raise ValueError(f"Unknown dataset: {dataset_name}")
+
+    @staticmethod
+    def find_neighbors(
+        X_train: np.ndarray,
+        test_point: np.ndarray,
+        k: int,
+        metric: str,
+    ) -> List[int]:
+        d = KNNService.compute_distance(test_point.reshape(1, -1), X_train, metric)[0]
+        return np.argsort(d)[:k].tolist()
