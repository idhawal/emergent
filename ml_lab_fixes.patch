+"""
+Regression Router - calls the from-scratch RegressionService.
+
+All five algorithms operate on the same polynomial design matrix
+[1, x, x^2, ..., x^poly_degree], so `poly_degree` is honoured for
+linear_gd, polynomial, ridge, lasso and elastic_net alike.
+"""
+
+from fastapi import APIRouter, HTTPException
+import numpy as np
+
+from app.models.regression_models import RegressionRequest, RegressionResponse
+from app.services.regression_service import RegressionService
+
+router = APIRouter()
+
+
+@router.post("/api/regression", response_model=RegressionResponse)
+async def run_regression(request: RegressionRequest) -> RegressionResponse:
+    try:
+        # 1. Synthetic dataset (deterministic seed for reproducibility)
+        X_raw, y = RegressionService.generate_synthetic_data(
+            n_samples=80,
+            noise=request.noise,
+            poly_degree=request.poly_degree,
+        )
+        scatter_x = X_raw[:, 0].tolist()
+        scatter_y = y.tolist()
+
+        # 2. Build a polynomial design matrix used by every algorithm
+        X = RegressionService.polynomial_features(X_raw, request.poly_degree, include_bias=True)
+        feature_names = RegressionService.feature_names(request.poly_degree)
+
+        # 3. Dispatch algorithm — all return (coef, cost_history)
+        stopped_at_epoch = None
+
+        if request.algo == "linear_gd":
+            theta, cost_history, stopped_at_epoch = RegressionService.gradient_descent(
+                X, y, request.learning_rate, request.epochs, request.early_stopping
+            )
+
+        elif request.algo == "polynomial":
+            theta = RegressionService.normal_equation(X, y)
+            cost_history = [RegressionService._mse_cost(theta, X, y)]
+
+        elif request.algo == "ridge":
+            theta = RegressionService.ridge_closed_form(X, y, request.penalty)
+            cost_history = [RegressionService._mse_cost(theta, X, y)]
+
+        elif request.algo == "lasso":
+            theta, cost_history = RegressionService.lasso_coordinate_descent(
+                X, y, request.penalty
+            )
+
+        elif request.algo == "elastic_net":
+            theta, cost_history = RegressionService.elastic_net_coordinate_descent(
+                X, y, request.penalty, request.l1_ratio
+            )
+
+        else:
+            raise HTTPException(status_code=422, detail=f"Unknown algorithm: {request.algo}")
+
+        # 4. Plot the fitted curve over a dense x-grid using the SAME polynomial basis
+        curve_x = np.linspace(-3, 3, 200).reshape(-1, 1)
+        curve_X = RegressionService.polynomial_features(curve_x, request.poly_degree, include_bias=True)
+        curve_y = curve_X @ theta
+
+        return RegressionResponse(
+            curve_x=curve_x[:, 0].tolist(),
+            curve_y=curve_y.tolist(),
+            scatter_x=scatter_x,
+            scatter_y=scatter_y,
+            cost_history=cost_history,
+            coefficients=theta.tolist(),
+            feature_names=feature_names,
+            stopped_at_epoch=stopped_at_epoch,
+        )
+
+    except HTTPException:
+        raise
+    except Exception as e:
+        raise HTTPException(status_code=500, detail=f"Internal server error: {str(e)}")
