+"""
+Genetic Algorithm Service - ML logic for real-coded genetic algorithms.
+
+This service implements real-coded genetic algorithms with Simulated Binary Crossover (SBX)
+and Polynomial Mutation for benchmark function optimization. All ML logic is isolated from
+FastAPI dependencies for testability.
+"""
+
+import numpy as np
+from typing import Tuple, List, Dict, Optional
+
+
+class GAService:
+    """Service class for genetic algorithm optimization."""
+    
+    # Benchmark function bounds
+    FUNCTION_BOUNDS = {
+        "sphere": (-5.0, 5.0),
+        "rosenbrock": (-2.0, 2.0),
+        "rastrigin": (-5.0, 5.0)
+    }
+    
+    @staticmethod
+    def evaluate_function(
+        function_name: str,
+        X: np.ndarray
+    ) -> np.ndarray:
+        """
+        Evaluate benchmark function on population.
+        
+        Functions:
+        - sphere: f(x,y) = x² + y²
+        - rosenbrock: f(x,y) = (1-x)² + 100(y-x²)²
+        - rastrigin: f(x,y) = 20 + (x²-10cos(2πx)) + (y²-10cos(2πy))
+        
+        Args:
+            function_name: Name of benchmark function
+            X: Population matrix (pop_size, 2)
+            
+        Returns:
+            fitness: Fitness values (pop_size,)
+        """
+        if function_name == "sphere":
+            # f(x,y) = x² + y²
+            return np.sum(X**2, axis=1)
+            
+        elif function_name == "rosenbrock":
+            # f(x,y) = (1-x)² + 100(y-x²)²
+            x, y = X[:, 0], X[:, 1]
+            return (1 - x)**2 + 100 * (y - x**2)**2
+            
+        elif function_name == "rastrigin":
+            # f(x,y) = 20 + (x²-10cos(2πx)) + (y²-10cos(2πy))
+            x, y = X[:, 0], X[:, 1]
+            return 20 + (x**2 - 10 * np.cos(2 * np.pi * x)) + (y**2 - 10 * np.cos(2 * np.pi * y))
+            
+        else:
+            raise ValueError(f"Unknown function: {function_name}")
+    
+    @staticmethod
+    def generate_contour(
+        function_name: str,
+        grid_resolution: int = 60
+    ) -> Tuple[np.ndarray, np.ndarray, np.ndarray]:
+        """
+        Generate contour plot data for benchmark function.
+        
+        Args:
+            function_name: Name of benchmark function
+            grid_resolution: Grid size (default 60)
+            
+        Returns:
+            contour_x, contour_y, contour_z: Meshgrid arrays (60, 60)
+        """
+        # Get bounds for function
+        bounds = GAService.FUNCTION_BOUNDS[function_name]
+        x_min, x_max = bounds
+        y_min, y_max = bounds
+        
+        # Create meshgrid
+        x = np.linspace(x_min, x_max, grid_resolution)
+        y = np.linspace(y_min, y_max, grid_resolution)
+        xx, yy = np.meshgrid(x, y)
+        
+        # Flatten and evaluate
+        grid_points = np.column_stack([xx.ravel(), yy.ravel()])
+        zz_flat = GAService.evaluate_function(function_name, grid_points)
+        
+        # Reshape
+        zz = zz_flat.reshape(xx.shape)
+        
+        return xx, yy, zz
+    
+    @staticmethod
+    def sbx_crossover(
+        parent1: np.ndarray,
+        parent2: np.ndarray,
+        eta_c: float,
+        bounds: Tuple[float, float]
+    ) -> Tuple[np.ndarray, np.ndarray]:
+        """
+        Simulated Binary Crossover (SBX).
+        
+        Algorithm:
+        1. For each dimension:
+           a. Generate random u ∈ [0,1]
+           b. Compute β using distribution index ηc:
+              If u ≤ 0.5: β = (2u)^(1/(ηc+1))
+              Else: β = (1/(2(1-u)))^(1/(ηc+1))
+           c. Compute offspring:
+              child1 = 0.5[(1+β)parent1 + (1-β)parent2]
+              child2 = 0.5[(1-β)parent1 + (1+β)parent2]
+           d. Clip to bounds
+        
+        Args:
+            parent1, parent2: Parent vectors
+            eta_c: Distribution index (higher = more similar to parents)
+            bounds: (min, max) for each dimension
+            
+        Returns:
+            child1, child2: Offspring vectors
+        """
+        n_dims = len(parent1)
+        
+        # Generate random u for all dimensions at once
+        u = np.random.random(n_dims)
+        
+        # Compute beta vectorized
+        beta = np.where(
+            u <= 0.5,
+            (2 * u) ** (1 / (eta_c + 1)),
+            (1 / (2 * (1 - u))) ** (1 / (eta_c + 1))
+        )
+        
+        # Compute offspring vectorized
+        child1 = 0.5 * ((1 + beta) * parent1 + (1 - beta) * parent2)
+        child2 = 0.5 * ((1 - beta) * parent1 + (1 + beta) * parent2)
+        
+        # Clip to bounds
+        child1 = np.clip(child1, bounds[0], bounds[1])
+        child2 = np.clip(child2, bounds[0], bounds[1])
+        
+        return child1, child2
+    
+    @staticmethod
+    def polynomial_mutation(
+        individual: np.ndarray,
+        eta_m: float,
+        bounds: Tuple[float, float],
+        mutation_rate: float
+    ) -> np.ndarray:
+        """
+        Polynomial Mutation.
+        
+        Algorithm:
+        1. For each dimension with probability mutation_rate:
+           a. Generate random r ∈ [0,1]
+           b. Compute δ using distribution index ηm:
+              If r < 0.5: δ = (2r)^(1/(ηm+1)) - 1
+              Else: δ = 1 - (2(1-r))^(1/(ηm+1))
+           c. Mutate: x' = x + δ * (upper_bound - lower_bound)
+           d. Clip to bounds
+        
+        Args:
+            individual: Individual vector
+            eta_m: Distribution index (higher = smaller perturbations)
+            bounds: (min, max) for each dimension
+            mutation_rate: Probability of mutating each dimension
+            
+        Returns:
+            mutated_individual: Mutated vector
+        """
+        n_dims = len(individual)
+        
+        # Determine which dimensions mutate (vectorized)
+        mask = np.random.random(n_dims) < mutation_rate
+        
+        # Generate random r for all dimensions
+        r = np.random.random(n_dims)
+        
+        # Compute delta vectorized
+        delta = np.where(
+            r < 0.5,
+            (2 * r) ** (1 / (eta_m + 1)) - 1,
+            1 - (2 * (1 - r)) ** (1 / (eta_m + 1))
+        )
+        
+        # Apply mutation only where mask is True
+        mutated = individual + mask * delta * (bounds[1] - bounds[0])
+        
+        # Clip to bounds
+        mutated = np.clip(mutated, bounds[0], bounds[1])
+        
+        return mutated
+    
+    @staticmethod
+    def optimize(
+        function_name: str,
+        pop_size: int,
+        mutation_rate: float,
+        crossover_rate: float,
+        generations: int,
+        eta_m: float,
+        eta_c: float,
+        random_state: int = 42,
+    ) -> Tuple[List[Dict], Optional[int]]:
+        """
+        Execute real-coded genetic algorithm.
+        
+        Algorithm:
+        1. Initialize population uniformly in function bounds
+        2. For each generation:
+           a. Evaluate fitness for all individuals
+           b. Record generation statistics
+           c. Select parents (tournament selection)
+           d. Apply SBX crossover with probability crossover_rate
+           e. Apply polynomial mutation with probability mutation_rate
+           f. Replace population with offspring
+           g. Check convergence
+        3. Return history and convergence generation
+        
+        Args:
