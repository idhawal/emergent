+// True when there is *no* HTTP response (DNS failure, CORS, server down, etc.).
+const isNetworkError = (err) =>
+  !err?.response || err?.code === "ERR_NETWORK" || err?.code === "ECONNABORTED";
+
+// Distill a backend error into a short, useful message.
+const formatServerError = (err) => {
+  if (!err?.response) return err?.message || "Unknown error";
+  const { status, data } = err.response;
+  if (data?.detail && typeof data.detail === "string") return `${status} — ${data.detail}`;
+  if (data?.detail && Array.isArray(data.detail)) {
+    const first = data.detail[0];
+    const loc = Array.isArray(first?.loc) ? first.loc.join(".") : "input";
+    return `${status} — ${loc}: ${first?.msg || "validation failed"}`;
+  }
+  return `${status} — ${err.message || "request failed"}`;
+};
+
+async function callOrMock(endpoint, req, mockFn, label) {
+  try {
+    const { data } = await client.post(endpoint, req);
+    return data;
+  } catch (err) {
+    if (isNetworkError(err)) {
+      console.warn(`[api] Backend unreachable for ${label} — using mock`);
+      toast.warning(`${label} backend unreachable — showing mock data`, {
+        id: `mock-${label}`,
+        duration: 4000,
+      });
+      return mockFn(req);
+    }
+    const msg = formatServerError(err);
+    console.error(`[api] ${label} backend error:`, msg);
+    toast.error(`${label} failed: ${msg}`, { id: `err-${label}`, duration: 6000 });
+    throw new Error(msg);
+  }
+}
