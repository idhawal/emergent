# Backend Environment Variables - Copy to .env
# This file contains configuration for the ML Visualizer backend API

# FastAPI Server Configuration
PORT=8000

# Frontend CORS Origin
# For development: http://localhost:3000
# For production: https://emergent-six-zeta.vercel.app
FRONTEND_URL=https://emergent-six-zeta.vercel.app

# Logging Configuration
LOG_LEVEL=INFO

# Database (if using in future)
# DATABASE_URL=

# Authentication (if using in future)
# SECRET_KEY=your-secret-key

